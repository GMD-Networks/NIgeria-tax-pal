# Copy to php-api/.env.local (DO NOT COMMIT)
# Values here are for local runtime only.

# Required for AI
# OpenAI:
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-4o-mini
# DeepSeek (OpenAI-compatible):
# AI_API_URL=https://api.deepseek.com/v1/chat/completions
# AI_MODEL=deepseek-chat
AI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
OCR_AI_PROVIDER=
OCR_AI_API_URL=
OCR_AI_API_KEY=
OCR_AI_MODEL=

# Document conversion (LibreOffice)
CONVERT_BIN=soffice
CONVERT_TMP_DIR=
CONVERT_TIMEOUT=90

# Required for Flutterwave payments
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_WEBHOOK_HASH=

# SMTP (optional but needed for real outbound mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=TaxPal

# App URLs (optional)
APP_URL=http://127.0.0.1:5173
API_URL=http://127.0.0.1:8101/api

# Security (recommended)
JWT_SECRET=
JWT_EXPIRY=2592000
